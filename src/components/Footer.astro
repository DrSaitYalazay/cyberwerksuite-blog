---
import { getLangFromUrl, useTranslations } from "../i18n/ui";
import CWSShield from "./CWSShield.astro";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="border-t border-border bg-subtle mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 grid gap-8 sm:grid-cols-3">
    <div class="space-y-3">
      <div class="flex items-center gap-2.5">
        <CWSShield size={32} />
        <div class="leading-tight">
          <div class="font-extrabold text-primary text-sm tracking-wider">CWS</div>
          <div class="text-[8px] text-muted font-semibold tracking-[0.18em] uppercase">
            Cyber<span class="text-accent">Werk</span>Suite
          </div>
        </div>
      </div>
      <p class="text-xs text-muted italic">{t("footer.tagline")}</p>
    </div>
    <div>
      <h4 class="font-semibold text-sm mb-2 text-ink">{t("footer.legal")}</h4>
      <ul class="space-y-1.5 text-sm">
        <li><a href="https://www.cyberwerksuite.com/impressum" class="text-muted hover:text-accent">{t("footer.imprint")}</a></li>
        <li><a href="https://www.cyberwerksuite.com/datenschutz" class="text-muted hover:text-accent">{t("footer.privacy")}</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold text-sm mb-2 text-ink">CyberWerkSuite</h4>
      <ul class="space-y-1.5 text-sm">
        <li><a href="https://www.cyberwerksuite.com" class="text-muted hover:text-accent">www.cyberwerksuite.com</a></li>
        <li><a href="mailto:info@cyberwerksuite.com" class="text-muted hover:text-accent">info@cyberwerksuite.com</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 text-xs text-muted">
      © {year} CyberWerkSuite. {t("footer.rights")}
    </div>
  </div>
</footer>
